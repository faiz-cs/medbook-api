# ============================================================
#  MEDBOOK INDIA — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=MedBook India
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medbook_db
DB_USER=medbook_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# ── OTP ───────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=5

# ── MSG91 (SMS) ───────────────────────────────────────────────
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=MEDBK
MSG91_TEMPLATE_ID=your_dlt_template_id

# ── Gupshup (WhatsApp) ────────────────────────────────────────
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_SOURCE_NUMBER=+91XXXXXXXXXX
GUPSHUP_APP_NAME=MedBook

# ── Firebase (FCM Push) ───────────────────────────────────────
FIREBASE_PROJECT_ID=medbook-india
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@medbook-india.iam.gserviceaccount.com

# ── AWS S3 ────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=medbook-uploads
AWS_CLOUDFRONT_URL=https://cdn.medbook.in

# ── Razorpay (Phase 2) ────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Slot Generation ───────────────────────────────────────────
SLOT_GENERATION_DAYS_AHEAD=60
SLOT_LOCK_MINUTES=5

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/medbook.log
